{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  // Turbo runs in strict env mode by default, which hides undeclared system env
  // vars from task processes. SYNCKIT_TIMEOUT must reach ESLint's synckit worker
  // (used by better-tailwindcss/enforce-canonical-classes) so it can't be the
  // value of any cache key — pass it through without folding it into the hash.
  "globalPassThroughEnv": ["SYNCKIT_TIMEOUT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@meldrank/web#build": {
      "dependsOn": ["^build"],
      // Inlined into the client bundle by `next build`, so it affects output and
      // must be part of the cache key — a changed key correctly busts the cache.
      // Strict env mode would otherwise hide it from the build process entirely.
      "env": ["NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
