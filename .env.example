# MeldRank environment contract — committed source of truth for variable names.
#
# Copy to `.env` and fill in real values for local development. Every variable
# below is declared in the Zod schema in `@meldrank/shared/server` (and the
# public web schema in `@meldrank/shared`); a CI check asserts this file and the
# schema stay in agreement. Placeholder values only — never commit real secrets.
#
# Which process needs what:
#   api    → DATABASE_URL, UPSTASH_*, CLERK_SECRET_KEY, INTERNAL_SPAWN_SECRET, SEAT_TICKET_SECRET, MATCH_INTERNAL_URL, WEB_APP_ORIGIN, PORT
#   match  → DATABASE_URL, UPSTASH_*, INTERNAL_SPAWN_SECRET, SEAT_TICKET_SECRET, PORT
#   bots   → DATABASE_URL, UPSTASH_*
#   web    → NEXT_PUBLIC_* (public, inlined into the client bundle)

# Process mode shared by every process: development | test | production.
NODE_ENV=development

# Listen port for the long-lived services (api defaults to 3001, match to 2567).
PORT=3001

# Neon Postgres connection string.
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Upstash Redis REST endpoint and token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Clerk server secret (apps/api). Public publishable key is the NEXT_PUBLIC one below.
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# API↔Match seam secrets (api + match). The internal secret gates the room-spawn
# endpoint; the seat-ticket secret is the HMAC key the API mints tickets with and
# the match room verifies at onAuth. Use long, random values in real environments.
INTERNAL_SPAWN_SECRET=dev-internal-spawn-secret
SEAT_TICKET_SECRET=dev-seat-ticket-secret

# Base URL of the match service's internal spawn endpoint (apps/api calls it).
MATCH_INTERNAL_URL=http://localhost:2567

# The single browser origin (apps/web) the API allowlists for cross-origin (CORS)
# requests. Must match the web app's served origin exactly (scheme + host + port).
WEB_APP_ORIGIN=http://localhost:3000

# Public web variables — inlined into the browser bundle, no secrets.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_MATCH_URL=http://localhost:2567
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
